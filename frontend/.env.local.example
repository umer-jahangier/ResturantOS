# Frontend environment variables (Doc 05 — Environment Variables).
# Copy to .env.local for local development. NEXT_PUBLIC_* are exposed to the browser.

# Gateway base URL — all API traffic goes through the Phase-3 API gateway.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# WebSocket base URL — live updates (KDS, notifications) in later phases.
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8080
